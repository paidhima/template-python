# Normalize line endings
* text=auto

# Force LF for source and config
*.py text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.json text eol=lf
*.cfg text eol=lf
*.txt text eol=lf
*.sh text eol=lf

# Binary files
*.png binary
*.jpg binary
*.ico binary
*.whl binary
